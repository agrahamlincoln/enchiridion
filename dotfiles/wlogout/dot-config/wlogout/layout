{
    "label" : "sleep",
    "action" : "bash -c 'killall wlogout; sleep 0.1; if [ -f ~/.config/hypr/use-hibernate ]; then systemctl hibernate; else systemctl suspend; fi'",
    "text" : "Sleep",
    "keybind" : "u"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "lock",
    "action" : "bash -c 'killall wlogout; sleep 0.1; grim /tmp/hyprlock-bg.png; loginctl lock-session'",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
