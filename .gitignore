.vscode/
.env

# claude-memory are useful, but don't need to be committed
.claude/
claude-memory/

# Auto-generated Hyprland host configs (varies per machine)
dotfiles/hypr/dot-config/hypr/layout-keybinds.conf
dotfiles/hypr/dot-config/hypr/host-settings.conf
dotfiles/hypr/dot-config/hypr/host-keybinds.conf
dotfiles/hypr/dot-config/hypr/host-type

# Archiso build artifacts and scaffolded releng files (regenerated by build.sh)
archiso/work/
archiso/out/
archiso/efiboot/
archiso/grub/
archiso/syslinux/
archiso/pacman.conf
archiso/bootstrap_packages
archiso/packages.x86_64
archiso/profiledef.sh
# Wi-Fi credentials (contains plaintext passphrase)
archiso/airootfs/var/

# Pre-built AUR packages (binary, version-specific)
archiso/airootfs/root/pkg/

# SSH keys and other secrets baked into the ISO
archiso/airootfs/root/secrets/

# Scaffolded airootfs files from releng (not our customizations)
archiso/airootfs/etc/*
!archiso/airootfs/etc/motd
!archiso/airootfs/etc/vconsole.conf
archiso/airootfs/usr/local/share/
archiso/airootfs/usr/local/bin/choose-mirror
archiso/airootfs/usr/local/bin/Installation_guide
archiso/airootfs/usr/local/bin/livecd-sound
archiso/airootfs/root/.automated_script.sh
archiso/airootfs/root/.zlogin
archiso/airootfs/root/.gnupg/
